# Large binaries live in c:\dev\tools, not here
*.exe
*.dll

# MSBuild intermediate output (redirected to %LOCALAPPDATA%\taskmon\obj\ by taskmon.csproj)
obj/

# Diagnostic / scratch files
*-test.ps1
*.log

# User settings (machine-specific, auto-created on first run)
voice-type/settings.json
tools/task-stats/tests/e2e/artifacts/

# 3d-viewer transient launch config (written by VBS launcher to %TEMP%, deleted after use)
# nothing to ignore here - the file lives in %TEMP%

# Environment variables - copy .env.example to .env and fill in your keys
.env

# Bun / Node dependencies and generated files
node_modules/
bun.lock
bun.lockb
package-lock.json
*.tsbuildinfo

# Editor / OS noise
.vs/
Thumbs.db
desktop.ini
